# Copy to .env at the repo root — every notebook loads it automatically.

# Model provider (one of these is required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider/model the agents use
VIDBYTE_COOKBOOK_PROVIDER=openai
VIDBYTE_COOKBOOK_MODEL=gpt-4.1

# Optional: live Vidbyte platform credentials (for api/ examples)
VIDBYTE_API_URL=
VIDBYTE_API_KEY=
